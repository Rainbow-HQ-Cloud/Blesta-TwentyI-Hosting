parameters:
    level: 6
    paths:
        - twentyi_hosting.php
        - apis
    excludePaths:
        - vendor
    ignoreErrors:
        # Blesta core classes are not available during static analysis
        - '#Class (Module|ModuleFields|Language|Loader) not found#'
        - '#Call to method .* of unknown class (Module|ModuleFields|Language|Loader)#'
