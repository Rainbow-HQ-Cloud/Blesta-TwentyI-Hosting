{
    "name": "blesta/twentyi-hosting",
    "description": "Blesta module for provisioning and managing 20i reseller hosting packages",
    "license": "MIT",
    "type": "blesta-module",
    "authors": [
        {
            "name": "Markus Simpson",
            "homepage": "https://github.com/markus-blesta-twentyi"
        }
    ],
    "require": {
        "php": ">=8.1",
        "20i/api-modules": "dev-master#696a5f1299cd2b1e67ae7f688d644ac800f41b67"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
